{
  "id": null,
  "uid": "vllm-engineering",
  "title": "VLLM Usage - Engineering",
  "tags": ["vllm", "engineering", "latency", "runtime", "multi-instance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "label": "Environment",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(service:up:raw:instance, env)",
        "query": {
          "query": "label_values(service:up:raw:instance, env)",
          "refId": "EnvVar"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "region",
        "type": "query",
        "label": "Region",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(service:up:raw:instance{env=~\"$env\"}, region)",
        "query": {
          "query": "label_values(service:up:raw:instance{env=~\"$env\"}, region)",
          "refId": "RegionVar"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "instance_name",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(service:up:raw:instance{env=~\"$env\",region=~\"$region\"}, instance_name)",
        "query": {
          "query": "label_values(service:up:raw:instance{env=~\"$env\",region=~\"$region\"}, instance_name)",
          "refId": "InstanceVar"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Requests Running",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(runtime:requests_running:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0, "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Requests Waiting",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(runtime:requests_waiting:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0, "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "KV Cache Usage",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(runtime:kv_cache_usage_perc:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Prefix Cache Hit Rate (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(runtime:prefix_cache_hit_rate5m:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Chat Error Rate (5m)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(http:chat_completions:error_rate5m:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Selected Instances Up",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(service:up:raw:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Request Concurrency by Instance",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "runtime:requests_running:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} running",
          "refId": "A"
        },
        {
          "expr": "runtime:requests_waiting:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} waiting",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latency Overview by Instance",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "latency:e2e:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} e2e p95",
          "refId": "A"
        },
        {
          "expr": "latency:ttft:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} ttft p95",
          "refId": "B"
        },
        {
          "expr": "latency:itl:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} itl p95",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latency Breakdown by Instance",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "latency:queue_time:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} queue p95",
          "refId": "A"
        },
        {
          "expr": "latency:prefill_time:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} prefill p95",
          "refId": "B"
        },
        {
          "expr": "latency:decode_time:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} decode p95",
          "refId": "C"
        },
        {
          "expr": "latency:inference_time:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} inference p95",
          "refId": "D"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Cache Efficiency by Instance",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "runtime:kv_cache_usage_perc:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} kv cache usage",
          "refId": "A"
        },
        {
          "expr": "runtime:prefix_cache_hit_rate5m:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} prefix cache hit rate",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Chat Requests by Status and Instance",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "http:chat_completions:requests:rate5m:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Chat Latency p95 by Instance",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "http:chat_completions:latency:p95:instance{env=~\"$env\",region=~\"$region\",instance_name=~\"$instance_name\"}",
          "legendFormat": "{{instance_name}} http p95",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      }
    }
  ]
}