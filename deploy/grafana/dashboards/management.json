{
  "id": null,
  "uid": "vllm-management",
  "title": "VLLM Usage - Management",
  "tags": ["vllm", "usage", "management"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Requests (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(usage:requests:rolling24h)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "type": "stat",
      "title": "Prompt Tokens (24h)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(usage:prompt_tokens:rolling24h)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Generation Tokens (24h)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(usage:generation_tokens:rolling24h)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Tokens (24h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(usage:tokens:rolling24h)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests Trend",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(usage:requests:increase1h)",
          "legendFormat": "requests/hour",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens Trend",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(usage:tokens:increase1h)",
          "legendFormat": "tokens/hour",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Service Availability",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "service:up:raw",
          "legendFormat": "raw_up",
          "refId": "A"
        },
        {
          "expr": "service:availability:business_hours",
          "legendFormat": "business_hours_up",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    }
  ]
}